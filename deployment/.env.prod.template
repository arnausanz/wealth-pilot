# WealthPilot — Producció (.env.prod)
# Còpia a: /opt/wealthpilot/.env.prod
# Permisos: chmod 600 /opt/wealthpilot/.env.prod

ENV=production
APP_VERSION=2.0.0

# Base de dades (PostgreSQL de la VM)
DATABASE_URL=postgresql+asyncpg://wealthpilot_db:CONTRASENYA@localhost:5432/wealthpilot

# Seguretat (genera amb: openssl rand -hex 32)
SECRET_KEY=CANVIA_PER_SECRET_SEGUR

# CORS — URL pública de l'app (sslip.io o domini propi)
CORS_ORIGINS=https://XXX-XXX-XXX-XXX.sslip.io

# Logs
LOG_LEVEL=INFO
