# ─── Oracle Cloud Production — còpia a /opt/wealthpilot/.env.prod ────────────
# Les diferències respecte al .env local:
#   - DATABASE_URL apunta a localhost (no "db" que és el hostname de Docker)
#   - ENV=production
#   - LOG_LEVEL=info
#   - CORS_ORIGINS apunta al domini real (o la IP pública mentre no hi hagi domini)

# ─── Database ────────────────────────────────────────────────────────────────
# ⚠️  POSTGRES_* no calen aquí (docker-compose no corre a producció)
#     Només necessites DATABASE_URL
DATABASE_URL=postgresql+asyncpg://wealthpilot_user:CANVIA_AIXÒ@localhost:5432/wealthpilot

# ─── App ─────────────────────────────────────────────────────────────────────
ENV=production
LOG_LEVEL=info
APP_VERSION=0.1.0

# ─── CORS — IP pública o domini quan estigui disponible ──────────────────────
CORS_ORIGINS=http://IP_PUBLICA_ORACLE
# Quan tinguis domini:
# CORS_ORIGINS=https://el-teu-domini.com
